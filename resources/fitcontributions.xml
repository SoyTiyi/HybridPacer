<fitContributions xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance" xsi:noNamespaceSchemaLocation="https://developer.garmin.com/downloads/connect-iq/resources.xsd">

    <!-- id MUST match FIT_ID_* constants in HybridFitSession.mc -->

    <!-- 0: race_cycle_id — Current race cycle (0-7) -->
    <fitField id="0" displayInChart="true" sortOrder="0" precision="0"
        chartTitle="@Strings.fitCycleTitle"
        dataLabel="@Strings.fitCycleLabel"
        unitLabel="@Strings.fitCycleUnit"
        fillColor="#FF6600" />

    <!-- 1: race_fsm_state — FSM state (0=WARMUP…5=FINISH) -->
    <fitField id="1" displayInChart="true" sortOrder="1" precision="0"
        chartTitle="@Strings.fitStateTitle"
        dataLabel="@Strings.fitStateLabel"
        unitLabel="@Strings.fitStateUnit"
        fillColor="#0066FF" />

    <!-- 2: transition_total_time — Cumulative time in Transition (s) -->
    <fitField id="2" displayInChart="true" sortOrder="2" precision="0"
        chartTitle="@Strings.fitTransitionTitle"
        dataLabel="@Strings.fitTransitionLabel"
        unitLabel="@Strings.fitTransitionUnit"
        fillColor="#9900CC" />

    <!-- 3: station_elapsed — Elapsed time in the current workout station (s) -->
    <fitField id="3" displayInChart="true" sortOrder="3" precision="0"
        chartTitle="@Strings.fitStationTitle"
        dataLabel="@Strings.fitStationLabel"
        unitLabel="@Strings.fitStationUnit"
        fillColor="#CC0000" />

    <!-- 4: active_athlete — Active athlete in doubles mode (1=active, 0=waiting) -->
    <fitField id="4" displayInChart="false" sortOrder="4" precision="0"
        chartTitle="@Strings.fitAthleteTitle"
        dataLabel="@Strings.fitAthleteLabel"
        unitLabel="@Strings.fitAthleteUnit"
        fillColor="#00CC00" />

    <!-- 5: pace_delta_deviation — Pace deviation vs. dynamic target (s/km) -->
    <fitField id="5" displayInChart="true" sortOrder="5" precision="1"
        chartTitle="@Strings.fitPaceTitle"
        dataLabel="@Strings.fitPaceLabel"
        unitLabel="@Strings.fitPaceUnit"
        fillColor="#CCCC00" />

    <!-- 6: work_rest_ratio — Running time / rest time ratio -->
    <fitField id="6" displayInChart="true" sortOrder="6" precision="2"
        chartTitle="@Strings.fitWorkRestTitle"
        dataLabel="@Strings.fitWorkRestLabel"
        unitLabel="@Strings.fitWorkRestUnit"
        fillColor="#00CCCC" />

</fitContributions>
